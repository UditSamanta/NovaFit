# SparkyFitness Environment Variables
# Docker Development Configuration

# --- PostgreSQL Database Settings ---
SPARKY_FITNESS_DB_NAME=sparkyfitness_db
SPARKY_FITNESS_DB_USER=sparky
SPARKY_FITNESS_DB_PASSWORD=changeme_db_password
SPARKY_FITNESS_DB_HOST=sparkyfitness-db
SPARKY_FITNESS_DB_PORT=5432

# --- Backend Server Settings ---
SPARKY_FITNESS_SERVER_HOST=sparkyfitness-server
SPARKY_FITNESS_SERVER_PORT=3010

# Frontend URL for Docker development
SPARKY_FITNESS_FRONTEND_URL=http://localhost:8081

# Logging level
SPARKY_FITNESS_LOG_LEVEL=INFO

# Node.js environment mode
NODE_ENV=development

# Server timezone
TZ=Etc/UTC

# --- Security Settings ---
# 64-character hex string for data encryption
SPARKY_FITNESS_API_ENCRYPTION_KEY=fe65f457da41f3b1940446cf88b7e3c640f3dee3b141b0e88c865eb76b43f2ac

# JWT secret key
JWT_SECRET=c479d5644c07706be41ed40466e3cce74e40713287c0933e9058cd5072d5e6c8

# --- Signup Settings ---
SPARKY_FITNESS_DISABLE_SIGNUP=false

# Admin email (optional)
# SPARKY_FITNESS_ADMIN_EMAIL=admin@example.com

# --- Email Settings (optional - leave empty for development) ---
# SPARKY_FITNESS_EMAIL_HOST=
# SPARKY_FITNESS_EMAIL_PORT=
# SPARKY_FITNESS_EMAIL_SECURE=
# SPARKY_FITNESS_EMAIL_USER=
# SPARKY_FITNESS_EMAIL_PASS=
# SPARKY_FITNESS_EMAIL_FROM=

# --- Login Management ---
SPARKY_FITNESS_FORCE_EMAIL_LOGIN=true

# --- Garmin Service ---
GARMIN_MICROSERVICE_URL=http://sparkyfitness-garmin:8000
GARMIN_SERVICE_PORT=8000
GARMIN_SERVICE_IS_CN=false

# --- Frontend Port ---
SPARKY_FITNESS_FRONTEND_PORT=8081
